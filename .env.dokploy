# ===============================
# InsForge - Dokploy (.env.dokploy)
# ===============================

# --- Dominio público principal de InsForge (API + dashboard/backend web) ---
API_BASE_URL=https://neurona-aplication-backend.shyntai.com
VITE_API_BASE_URL=https://neurona-aplication-backend.shyntai.com

# --- Base de datos interna (no expuesta al host) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_POSTGRES_MUY_SEGURA
POSTGRES_DB=insforge

# --- Seguridad (OBLIGATORIO: 32+ chars, diferentes entre sí) ---
JWT_SECRET=CAMBIAR_JWT_SECRET_32_O_MAS_CARACTERES
ENCRYPTION_KEY=CAMBIAR_ENCRYPTION_KEY_32_O_MAS_CARACTERES

# --- Usuario admin inicial ---
ADMIN_EMAIL=admin@shyntai.com
ADMIN_PASSWORD=CAMBIAR_ADMIN_PASSWORD_MUY_SEGURA

# --- Opcional: API key interna (si no, puede autogenerarse) ---
ACCESS_API_KEY=ik_CAMBIAR_API_KEY_32_O_MAS_CARACTERES

# --- Runtime de funciones (Deno) ---
WORKER_TIMEOUT_MS=60000

# --- IA (opcional) ---
OPENROUTER_API_KEY=

# --- OAuth (opcional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# --- Storage S3 (opcional; si va vacío usa volumen local) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
S3_ENDPOINT_URL=

# --- Límites opcionales ---
MAX_FILE_SIZE=
MAX_JSON_BODY_SIZE=100mb
MAX_URLENCODED_BODY_SIZE=10mb
